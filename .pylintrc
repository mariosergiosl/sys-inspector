[MASTER]
# A comma-separated list of package or module names from where C extensions may
# be loaded. Extensions are loading into the active Python interpreter and may
# run arbitrary code.
extension-pkg-whitelist=bcc

[MESSAGES CONTROL]
# C0114: Missing module docstring (we use header blocks instead)
# C0103: Variable name doesn't conform to snake_case (we adhere to BPF/C naming conventions sometimes)
# R0902: Too many instance attributes (ProcessNode needs many attributes for forensics)
# W0703: Catching too general exception (Necessary for volatile /proc scanning)
# R0402: Use 'from X import Y' (We prefer explicit imports for namespace clarity)
# W0621: Redefining name from outer scope (Common in small scripts)
# R0903: Too few public methods (We use classes as data Structs)
# W0602: Global variable not assigned (BCC requires 'global b' for callbacks)
# W0613: Unused argument (BCC callbacks have mandatory fixed signature)
# W0601: Global variable undefined (BCC pattern)
# W0603: Using the global statement (global-statement)
# C0301: Line too long (Embedded HTML and C inevitably generate long lines)
# C0115: Missing class docstring
# C0116: Missing function docstring
# R0917: Too many positional arguments (6/5) (too-many-positional-arguments)
# W0702: No exception type(s) specified (bare-except, used in web_controller AJAX fallback)
# R0914: Too many local variables (used in web_controller rendering)
# C0321: More than one statement on a single line (multiple-statements)
# W1514: Using open without explicitly specifying an encoding (unspecified-encoding)
# W0612: Unused variable
# W1203: Use lazy % formatting in logging functions (logging-fstring-interpolation)
# C0415: Import outside toplevel
# W0212: Access to a protected member _exit of a client class
# R0915: Too many statements
# R0912: Too many branches
# R0801: Similar lines
# R1714: Consider merging these comparisons with "in"
# R1732: Consider using 'with'
# W0201: Attribute 'immutable_alert' defined outside __init__
# R1715: Consider using dict.get for getting values from a dict if a key is present or a default if not 
# R1723: Unnecessary "elif" after "break", remove the leading "el" from "elif"
# W1309: Using an f-string that does not have any interpolated variables
# R0201: Method could be a function
# R1719: The if expression can be replaced with 'test'
# W1201: Use lazy % formatting in logging functions
disable=W1201, R1719, R0201, W1309, R1723, R1715, W0201, R1732, R1714, R0801, R0912, R0915, W0212, C0415, W1203, W0612, W1514, C0114, C0103, R0902, W0703, R0402, W0621, R0903, W0602, W0613, W0601, C0301, C0115, C0116, W0603, R0917, W0702, R0914, C0321

[FORMAT]
# Maximum number of characters on a single line.
max-line-length=200

[DESIGN]
# Maximum number of arguments for function / method.
max-args=10

# Maximum number of attributes for a class (see R0902 disabled above, but keeping limit sane)
max-attributes=25

# Maximum number of boolean expressions in an if statement.
max-bool-expr=5

# Maximum number of branch for function / method body.
max-branches=25

# Maximum number of locals for function / method body.
max-locals=30

# Maximum number of parents for a class (see R0901).
max-parents=7

# Maximum number of public methods for a class (see R0904).
max-public-methods=20

# Maximum number of return / yield for function / method body.
max-returns=10

# Maximum number of statements in function / method body.
max-statements=100
